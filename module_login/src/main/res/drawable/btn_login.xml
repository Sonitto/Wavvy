<!-- res/drawable/btn_glass_selector.xml -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 按下状态：更透更暗 -->
    <item android:state_pressed="true">
        <shape>
            <gradient
                android:startColor="#30FFFFFF"
                android:endColor="#08FFFFFF"
                android:angle="45" />
            <stroke
                android:width="1.5dp"
                android:color="#60FFFFFF" />
            <corners android:radius="25dp" />
        </shape>
    </item>

    <!-- 默认状态 -->
    <item>
        <shape>
            <gradient
                android:startColor="#40B3D9FF"
                android:endColor="#10B3D9FF"
                android:angle="45" />
            <stroke
                android:width="1.5dp"
                android:color="#90FFFFFF" />
            <corners android:radius="25dp" />
        </shape>
    </item>
</selector>