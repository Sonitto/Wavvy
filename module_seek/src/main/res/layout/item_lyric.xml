<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:paddingTop="15dp">
    <TextView
        android:id="@+id/tv_lyric_name"
        android:text="红豆"
        android:textStyle="bold"
        android:textColor="@color/text"
        android:textSize="19sp"
        android:layout_marginStart="40dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
    <TextView
        android:layout_marginStart="40dp"
        app:layout_constraintStart_toStartOf="parent"
        android:id="@+id/tv_ci"
        android:text="歌词"
        app:layout_constraintTop_toBottomOf="@id/tv_lyric_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
    <TextView
        android:id="@+id/tv_lyric"
        android:layout_marginStart="10dp"
        app:layout_constraintTop_toBottomOf="@id/tv_lyric_name"
        app:layout_constraintStart_toEndOf="@id/tv_ci"
        android:layout_width="320dp"
        android:maxLines="1"
        android:layout_height="wrap_content"/>
    <TextView
        android:id="@+id/geshou"
        android:text="歌手"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="40dp"
        app:layout_constraintTop_toBottomOf="@id/tv_ci"/>
    <TextView
        android:layout_marginStart="10dp"
        android:id="@+id/tv_lyric_author"
        app:layout_constraintStart_toEndOf="@id/geshou"
        app:layout_constraintTop_toBottomOf="@id/tv_lyric"
        android:layout_width="320dp"
        android:maxLines="1"
        android:layout_height="wrap_content"/>



</androidx.constraintlayout.widget.ConstraintLayout>