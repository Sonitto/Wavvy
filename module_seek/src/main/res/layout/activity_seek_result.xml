<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context="com.wavvy.seek.view.SeekResultActivity">
    <LinearLayout
        android:id="@+id/toolbar_search_result"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="-10dp"
        android:gravity="center_vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btn_result_back"
            android:layout_width="20sp"
            android:layout_height="16dp"
            android:gravity="center" />
        <LinearLayout
            android:id="@+id/bar_inner_result"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:background="@drawable/shape_searchbar"
            android:gravity="center_vertical"
            android:padding="5dp"
            >

            <ImageView
                android:src="@drawable/seek_search"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
            <EditText
                android:id="@+id/et_seek"
                android:layout_width="250dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:background="@drawable/shape_searchbar"
                android:textSize="15sp"
                android:hint="输入艺人，音乐以及更多"
                />


        </LinearLayout>
        <TextView
            android:id="@+id/tv_seek"
            android:layout_width="50dp"
            android:layout_height="30dp"
            android:gravity="center"
            android:text="搜索"/>

    </LinearLayout>
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tablelayout_seek_result"
        app:layout_constraintTop_toBottomOf="@id/toolbar_search_result"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        app:tabMode="scrollable"/>
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/vp2_result_seek"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tablelayout_seek_result"/>


</androidx.constraintlayout.widget.ConstraintLayout>